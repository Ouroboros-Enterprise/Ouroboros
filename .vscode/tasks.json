{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Pascal",
            "type": "shell",
            "command": "fpc",
            "args": [
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Compile Java",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/Java/run.ps1",
                "-CompileOnly"
            ],
            "group": "build"
        },
        {
            "label": "Run Java",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/Java/run.ps1"
            ]
        }
    ]
}